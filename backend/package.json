{
  "name": "petpal-backend",
  "version": "1.0.0",
  "description": "PetPal AI-powered pet health diagnosis backend",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node dist/server.js",
    "build": "robocopy . dist /E /XD dist node_modules && exit 0",
    "clean": "rmdir /S /Q dist",
    "rebuild": "npm run clean && npm run build",
    "test": "jest --forceExit --detectOpenHandles",
    "test:verbose": "jest --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "chromadb": "^1.7.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "json-logic-js": "^2.0.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.4"
  }
}
